# Copy to .env and adjust. Node loads .env automatically (process.loadEnvFile).

# Base URL of the running backend, including the context_path prefix.
# Matches brain-sentry-go/config.yaml: server.port 8081 + context_path /api.
BS_BASE_URL=http://localhost:8081/api

# Tenant the requests run under. Defaults to config.yaml tenant.default_id.
BS_TENANT_ID=a9f814d2-4dae-41f3-851b-8aa3d4706561

# Auth mode. "demo" calls POST /v1/auth/demo (no credentials needed).
# Set "login" to use BS_EMAIL / BS_PASSWORD against POST /v1/auth/login.
BS_AUTH_MODE=demo
BS_EMAIL=
BS_PASSWORD=
